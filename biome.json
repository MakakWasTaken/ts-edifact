{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "files": {
    "ignoreUnknown": true
  },
  "formatter": {
    "includes": [
      "**",
      "!**/coverage/**",
      "!**/node_modules/**",
      "!**/build/**",
      "!**/public/**",
      "!**/src/messageSpec/**",
      "!**/.vscode/**"
    ],
    "enabled": true,
    "formatWithErrors": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "includes": [
      "**",
      "!**/coverage/**",
      "!**/node_modules/**",
      "!**/build/**",
      "!**/public/**",
      "!**/src/messageSpec/**",
      "!**/.vscode/**"
    ],
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noParameterAssign": "off"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noAsyncPromiseExecutor": "off",
        "noAssignInExpressions": "off",
        "noConsole": { "level": "warn", "options": { "allow": ["log"] } }
      },
      "correctness": {
        "noUnusedVariables": "error"
      },
      "performance": {
        "noAccumulatingSpread": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  }
}
