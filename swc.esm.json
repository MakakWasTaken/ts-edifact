{
  "$schema": "https://json.schemastore.org/swcrc",
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "tsx": false,
      "decorators": false,
      "dynamicImport": true,
      "importAttributes": true
    },
    "target": "esnext",
    "keepClassNames": true,
    "loose": false
  },
  "module": {
    "type": "es6"
  },
  "sourceMaps": true
}
