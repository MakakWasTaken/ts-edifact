{
  "name": "@makakwastaken/ts-edifact",
  "description": "Edifact parser library",
  "version": "0.3.0",
  "type": "module",
  "module": "build/esm/src/index.js",
  "types": "build/esm/src/index.d.ts",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "edi",
    "edifact",
    "parser"
  ],
  "readme": "README.md",
  "author": {
    "name": "Roman Vottner"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MakakWasTaken/ts-edifact.git"
  },
  "homepage": "https://github.com/MakakWasTaken/ts-edifact/README.md",
  "bugs": {
    "url": "https://github.com/MakakWasTaken/ts-edifact/-/issues",
    "email": "markus@unknown-studios.com"
  },
  "contributors": [
    {
      "name": "Markus Moltke",
      "email": "markus@unknown-studios.com",
      "url": "https://unknown-studios.com"
    }
  ],
  "lint-staged": {
    "*.ts": [
      "biome lint --write",
      "biome format --write"
    ]
  },
  "scripts": {
    "clean": "rm -rf ./build ./dist",
    "lint": "biome format --write --no-errors-on-unmatched . && biome lint --write .",
    "check": "npm run check:tsc",
    "check:tsc": "tsc --noEmit",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest spec",
    "coverage": "yarn test --coverage",
    "lint:staged": "lint-staged",
    "prepack": "yarn lint && yarn build",
    "prepare": "husky || true",
    "build": "yarn build:esm",
    "build:esm": "swc src -d build/esm --config-file swc.esm.json --copy-files && node scripts/fix-json-imports.mjs && tsc -p tsconfig.build.json"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/types": "^21.0.1",
    "@initics/tsm": "^1.0.2",
    "@swc/cli": "^0.8.1",
    "@swc/jest": "^0.2.39",
    "@types/events": "3.0.3",
    "@types/htmlparser2": "^4.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.7.0",
    "domhandler": "^6.0.1",
    "events": "^3.3.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "lint-staged": "^17.0.4",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2"
  },
  "dependencies": {
    "@swc/core": "^1.15.33",
    "axios": "^1.16.1",
    "htmlparser2": "^12.0.0"
  },
  "files": [
    "build/**/*"
  ],
  "packageManager": "yarn@4.8.1",
  "exports": {
    ".": {
      "import": "./build/esm/src/index.js",
      "types": "./build/esm/src/index.d.ts"
    }
  }
}
